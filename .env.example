# SafeSight AI Backend Environment Variables

# To use email alerts, copy this file to .env and fill in your Gmail credentials.
# You MUST use a Gmail App Password, NOT your regular password.
# To generate an App Password: 
# 1. Go to your Google Account -> Security -> 2-Step Verification
# 2. At the bottom, click "App passwords"
# 3. Create a new app password and paste the 16-character code below without spaces.

EMAIL_SENDER="your-email@gmail.com"
EMAIL_PASSWORD="your-16-char-app-password"
